                                }
                            },
                            {
                                "box": {
                                    "code": "// DIN 45692 sharpness from Specific Loudness (0.1..24 Bark, 0.1 Bark step)\n// Ported from Sharpness_DIN45692_from_loudness.m\n\nconst NBARK = 240;\nconst DZ = 0.1;\nconst K = 0.11;\n\n// Weighting selector (matches your MATLAB weight_type strings)\n@param({ enum: [ \"din45692\", \"bismarck\", \"aures\" ] }) weightType = 0;\n\n// Precomputed per-bin weights for speed\n@state wDin  = new FixedFloatArray(NBARK);   // g(z)*z*DZ\n@state wBism = new FixedFloatArray(NBARK);   // g(z)*z*DZ\n@state aExp  = new FixedFloatArray(NBARK);   // exp(0.171*z)*DZ  (Aures simplification)\n\nfunction init() {\n    for (let i = 0; i < NBARK; i++) {\n        let z = (i + 1) * DZ; // 0.1 ... 24.0\n\n        // DIN 45692 weighting\n        let gDin = 1.0;\n        if (z >= 15.8) {\n            gDin = 0.15 * exp(0.42 * (z - 15.8)) + 0.85;\n        }\n        wDin[i] = gDin * z * DZ;\n\n        // \"Bismarck\" weighting (as in your MATLAB)\n        let gB = 1.0;\n        if (z >= 15.0) {\n            gB = 0.2 * exp(0.308 * (z - 15.0)) + 0.8;\n        }\n        wBism[i] = gB * z * DZ;\n\n        // Aures term:\n        // MATLAB: g(z)=0.078*(exp(0.171*z)/z)*(N/log(0.05*N+1))\n        // In sharpness numerator there's an extra \"*z\", and final \"/N\" cancels N:\n        // S = K * 0.078 * sum(Nspec * exp(0.171*z) * DZ) / log(0.05*N + 1)\n        aExp[i] = exp(0.171 * z) * DZ;\n    }\n}\n\n// --- Runtime: compute sharpness whenever listin1 arrives on hot inlet ---\nlet nIn = intnum(listlen(listin1));     // listlen naming rule: list.len -> listlen :contentReference[oaicite:1]{index=1}\nlet n = (nIn < NBARK) ? nIn : NBARK;\n\n// Total loudness (sones): sum(Nspec)*0.1\nlet N = 0.0;\n\n// Numerators\nlet num = 0.0;        // for DIN/Bismarck\nlet sumA = 0.0;       // for Aures (sum of Nspec*exp(0.171*z)*DZ)\n\nfor (let i = 0; i < n; i++) {\n    let Ns = listin1[i];\n    N += Ns * DZ;\n\n    if (weightType == 0) {\n        num += Ns * wDin[i];\n    } else if (weightType == 1) {\n        num += Ns * wBism[i];\n    } else {\n        sumA += Ns * aExp[i];\n    }\n}\n\nlet S = 0.0;\nif (N > 0.0) {\n    if (weightType == 2) {\n        let denom = log(0.05 * N + 1.0);\n        if (denom > 0.0) {\n            S = K * 0.078 * (sumA / denom);\n        } else {\n            S = 0.0;\n        }\n    } else {\n        S = K * (num / N);\n    }\n}\n\nout1 = S;  // sharpness (acum)\nout2 = N;  // loudness (sones)\n",
                                    "fontface": 0,
                                    "fontname": "<Monospaced>",
                                    "fontsize": 12.0,
                                    "id": "obj-20",
                                    "maxclass": "codebox",
                                    "numinlets": 1,
                                    "numoutlets": 2,
                                    "outlettype": [ "", "" ],
                                    "patching_rect": [ 39.0, 994.0, 617.0, 433.0 ],
                                    "rnbo_classname": "codebox",
                                    "rnbo_extra_attributes": {
                                        "nocache": 0,
                                        "hot": 0,
                                        "code": "// DIN 45692 sharpness from Specific Loudness (0.1..24 Bark, 0.1 Bark step)\n// Ported from Sharpness_DIN45692_from_loudness.m\n\nconst NBARK = 240;\nconst DZ = 0.1;\nconst K = 0.11;\n\n// Weighting selector (matches your MATLAB weight_type strings)\n@param({ enum: [ \"din45692\", \"bismarck\", \"aures\" ] }) weightType = 0;\n\n// Precomputed per-bin weights for speed\n@state wDin  = new FixedFloatArray(NBARK);   // g(z)*z*DZ\n@state wBism = new FixedFloatArray(NBARK);   // g(z)*z*DZ\n@state aExp  = new FixedFloatArray(NBARK);   // exp(0.171*z)*DZ  (Aures simplification)\n\nfunction init() {\n    for (let i = 0; i < NBARK; i++) {\n        let z = (i + 1) * DZ; // 0.1 ... 24.0\n\n        // DIN 45692 weighting\n        let gDin = 1.0;\n        if (z >= 15.8) {\n            gDin = 0.15 * exp(0.42 * (z - 15.8)) + 0.85;\n        }\n        wDin[i] = gDin * z * DZ;\n\n        // \"Bismarck\" weighting (as in your MATLAB)\n        let gB = 1.0;\n        if (z >= 15.0) {\n            gB = 0.2 * exp(0.308 * (z - 15.0)) + 0.8;\n        }\n        wBism[i] = gB * z * DZ;\n\n        // Aures term:\n        // MATLAB: g(z)=0.078*(exp(0.171*z)/z)*(N/log(0.05*N+1))\n        // In sharpness numerator there's an extra \"*z\", and final \"/N\" cancels N:\n        // S = K * 0.078 * sum(Nspec * exp(0.171*z) * DZ) / log(0.05*N + 1)\n        aExp[i] = exp(0.171 * z) * DZ;\n    }\n}\n\n// --- Runtime: compute sharpness whenever listin1 arrives on hot inlet ---\nlet nIn = intnum(listlen(listin1));     // listlen naming rule: list.len -> listlen :contentReference[oaicite:1]{index=1}\nlet n = (nIn < NBARK) ? nIn : NBARK;\n\n// Total loudness (sones): sum(Nspec)*0.1\nlet N = 0.0;\n\n// Numerators\nlet num = 0.0;        // for DIN/Bismarck\nlet sumA = 0.0;       // for Aures (sum of Nspec*exp(0.171*z)*DZ)\n\nfor (let i = 0; i < n; i++) {\n    let Ns = listin1[i];\n    N += Ns * DZ;\n\n    if (weightType == 0) {\n        num += Ns * wDin[i];\n    } else if (weightType == 1) {\n        num += Ns * wBism[i];\n    } else {\n        sumA += Ns * aExp[i];\n    }\n}\n\nlet S = 0.0;\nif (N > 0.0) {\n    if (weightType == 2) {\n        let denom = log(0.05 * N + 1.0);\n        if (denom > 0.0) {\n            S = K * 0.078 * (sumA / denom);\n        } else {\n            S = 0.0;\n        }\n    } else {\n        S = K * (num / N);\n    }\n}\n\nout1 = S;  // sharpness (acum)\nout2 = N;  // loudness (sones)\n",
                                        "safemath": 1
                                    },
                                    "rnbo_serial": 1,
                                    "rnbo_uniqueid": "codebox_obj-20",
