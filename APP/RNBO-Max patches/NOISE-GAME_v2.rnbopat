                                            {
                                                "box": {
                                                    "code": "@param({ min: 1, max: 20000}) fc = 1000;        // band center frequency (Hz)\n@param calib = 1;        // multiply input to get Pascals (Pa). Leave 1 if already calibrated\n@param iRef = 4e-10;     // Pa^2 reference (same as MATLAB I_REF)\n@param tiny = 1e-12;     // same as MATLAB TINY_VALUE\n\n@state y1 = 0;\n@state y2 = 0;\n@state y3 = 0;\n\n@state a1 = 0;\n@state b0 = 0;\n@state lastFc = -1;\n\nfunction updateCoeffs() {\n    let f = fc;\n    if (f <= 0) f = 1;\n\n    // MATLAB: Tau = 2/(3*min(fc,1000))\n    let fTau = (f > 1000) ? 1000 : f;\n    let tau = 2.0 / (3.0 * fTau);\n\n    a1 = exp(-1.0 / (samplerate * tau));\n    b0 = 1.0 - a1;\n    lastFc = fc;\n}\n\nif (fc != lastFc) updateCoeffs();\n\n// bandpassed input:\nlet x = in1 * calib;\n\n// intensity / power:\nlet p = x * x;\n\n// 3 cascaded one-poles:\ny1 = b0 * p + a1 * y1;\ny2 = b0 * y1 + a1 * y2;\ny3 = b0 * y2 + a1 * y3;\n\n// dB SPL:\nout1 = 10.0 * (log((y3 + tiny) / iRef) / ln10);\n",
                                                    "fontface": 0,
                                                    "fontname": "<Monospaced>",
                                                    "fontsize": 12.0,
                                                    "id": "obj-4",
                                                    "maxclass": "codebox~",
                                                    "numinlets": 1,
                                                    "numoutlets": 1,
                                                    "outlettype": [ "signal" ],
                                                    "patching_rect": [ 47.0, 338.0, 499.0, 270.0 ],
                                                    "rnbo_classname": "codebox~",
                                                    "rnbo_extra_attributes": {
                                                        "nocache": 0,
                                                        "expr": "",
                                                        "code": "@param({ min: 1, max: 20000}) fc = 1000;        // band center frequency (Hz)\n@param calib = 1;        // multiply input to get Pascals (Pa). Leave 1 if already calibrated\n@param iRef = 4e-10;     // Pa^2 reference (same as MATLAB I_REF)\n@param tiny = 1e-12;     // same as MATLAB TINY_VALUE\n\n@state y1 = 0;\n@state y2 = 0;\n@state y3 = 0;\n\n@state a1 = 0;\n@state b0 = 0;\n@state lastFc = -1;\n\nfunction updateCoeffs() {\n    let f = fc;\n    if (f <= 0) f = 1;\n\n    // MATLAB: Tau = 2/(3*min(fc,1000))\n    let fTau = (f > 1000) ? 1000 : f;\n    let tau = 2.0 / (3.0 * fTau);\n\n    a1 = exp(-1.0 / (samplerate * tau));\n    b0 = 1.0 - a1;\n    lastFc = fc;\n}\n\nif (fc != lastFc) updateCoeffs();\n\n// bandpassed input:\nlet x = in1 * calib;\n\n// intensity / power:\nlet p = x * x;\n\n// 3 cascaded one-poles:\ny1 = b0 * p + a1 * y1;\ny2 = b0 * y1 + a1 * y2;\ny3 = b0 * y2 + a1 * y3;\n\n// dB SPL:\nout1 = 10.0 * (log((y3 + tiny) / iRef) / ln10);\n",
                                                        "safemath": 1
                                                    },
                                                    "rnbo_serial": 1,
                                                    "rnbo_uniqueid": "codebox~_obj-4",
